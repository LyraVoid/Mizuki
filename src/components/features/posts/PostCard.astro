---
import { render } from "astro:content";
import { Icon } from "astro-icon/components";

import { getFileDirFromPath, getPostUrl, getTagUrl } from "@/utils/url-utils";

import { siteConfig } from "../../../config";
import I18nKey from "../../../i18n/i18nKey";
import { i18n } from "../../../i18n/translation";
import Image from "../../atoms/Image/Image.astro";
import PostMetadata from "./PostMeta.astro";
import type { PostCardProps } from "./types";

const { entry, style }: PostCardProps = Astro.props as PostCardProps;
const className = Astro.props.class;

const {
	title,
	published,
	updated,
	tags,
	category,
	image,
	description,
	pinned,
	encrypted,
	password,
} = entry.data;

const url = getPostUrl(entry);
const hasCover = image !== undefined && image !== null && image !== "";
const coverWidth = "28%";
const coverPosition = siteConfig.postListLayout?.coverPosition || "right";

const { remarkPluginFrontmatter } = await render(entry);
---

<div
	class:list={[
		"post-card-wrapper card-base flex w-full rounded-[var(--radius-large)] overflow-hidden relative",
		hasCover ? "has-cover" : "no-cover",
		coverPosition === "top" ? "cover-top" : "cover-right",
		{
			"flex-col-reverse md:flex-col": true,
		},
		className,
	]}
	style={style}
>
	<div
		class:list={[
			"post-card-content pl-6 md:pl-9 pr-6 pt-6 md:pt-7 pb-6 relative",
			{
				"md:pr-2": hasCover && coverPosition === "right",
				"md:pr-9": !hasCover || coverPosition === "top",
				"w-full md:w-[calc(100%_-_3.25rem_-_0.75rem)]": !hasCover,
				"w-full md:w-[calc(100%_-_var(--coverWidth)_-_0.75rem)]":
					hasCover && coverPosition === "right",
				"w-full": hasCover && coverPosition === "top",
			},
		]}
	>
		<a
			href={url}
			class="post-card-title-link transition group w-full block font-bold mb-3 text-3xl text-90
        hover:text-[var(--primary)] dark:hover:text-[var(--primary)]
        active:text-[var(--title-active)] dark:active:text-[var(--title-active)]
        before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
        before:absolute
        before:top-[2.1875rem] before:left-[1.125rem] before:hidden md:before:block"
		>
			{
				pinned && (
					<Icon
						name="mdi:pin"
						class="inline text-[var(--primary)] text-2xl mr-2 -translate-y-0.5"
					/>
				)
			}
			{title}
			{
				encrypted && password && (
					<Icon
						name="material-symbols:lock-outline"
						class="inline text-2xl align-middle -translate-y-px ml-2"
					/>
				)
			}
			<Icon
				class="inline text-[2rem] text-[var(--primary)] md:hidden translate-y-0.5 absolute"
				name="material-symbols:chevron-right-rounded"
			/>
			<Icon
				class="text-[var(--primary)] text-[2rem] transition hidden md:inline absolute translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0"
				name="material-symbols:chevron-right-rounded"
			/>
		</a>

		<PostMetadata
			published={published}
			updated={updated}
			tags={tags}
			category={category || ""}
			hideTagsForMobile={true}
			hideUpdateDate={true}
			className="post-card-meta mb-4"
			showOnlyBasicMeta={true}
			words={remarkPluginFrontmatter.words}
			showWordCount={true}
		/>

		<div
			class:list={[
				"post-card-description transition text-75 mb-3.5 pr-4",
				{ "line-clamp-2 md:line-clamp-1": !description },
			]}
		>
			{description || remarkPluginFrontmatter.excerpt}
		</div>

		<div class="post-card-tags flex flex-wrap gap-2 mt-2">
			{
				tags && tags.length > 0 ? (
					tags.map((tag) => (
						<a
							href={getTagUrl(tag)}
							class:list={[
								siteConfig.tagStyle?.useNewStyle
									? "link-lg transition text-50 text-xs font-medium px-2 py-1 rounded-lg hover:text-[var(--primary)] dark:hover:text-[var(--primary)] active:text-[var(--primary)] dark:active:text-[var(--primary)] group/tag whitespace-nowrap"
									: "btn-regular h-6 text-xs px-2 rounded-lg",
							]}
							aria-label={`View all posts tagged with ${tag.trim()}`}
						>
							<span class="transition-transform group-hover/tag:translate-x-0.5">
								# {tag.trim()}
							</span>
						</a>
					))
				) : (
					<span class="text-xs text-50">{i18n(I18nKey.noTags)}</span>
				)
			}
		</div>
	</div>

	{
		hasCover && (
			<a
				href={url}
				aria-label={title}
				class:list={[
					"post-card-image group relative rounded-xl overflow-hidden active:scale-95 max-h-[20vh] mx-4 mt-4 -mb-2",
					{
						"md:max-h-none md:mb-0 md:mx-0 md:mt-0 md:w-[var(--coverWidth)] md:absolute md:top-3 md:bottom-3 md:right-3":
							coverPosition === "right",
					},
				]}
			>
				<div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition" />
				<div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center ">
					<Icon
						name="material-symbols:chevron-right-rounded"
						class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl"
					/>
				</div>
				<Image
					src={image}
					basePath={getFileDirFromPath(entry.filePath || "")}
					alt="Cover Image of the Post"
					class="w-full h-full"
				/>
			</a>
		)
	}

	{
		!hasCover && (
			<a
				href={url}
				aria-label={title}
				class="post-card-enter-btn !hidden md:!flex btn-regular w-[3.25rem]
         absolute right-3 top-3 bottom-3 rounded-xl bg-[var(--enter-btn-bg)]
         hover:bg-[var(--enter-btn-bg-hover)] active:bg-[var(--enter-btn-bg-active)] active:scale-95
        "
			>
				<Icon
					name="material-symbols:chevron-right-rounded"
					class="transition text-[var(--primary)] text-4xl mx-auto"
				/>
			</a>
		)
	}
</div>
<div
	class="transition border-t-[1px] border-dashed mx-6 border-black/10 dark:border-white/[0.15] last:border-t-0 md:hidden"
>
</div>

<style define:vars={{ coverWidth }}>
	@reference "tailwindcss";

	:global(.list-mode) .cover-top.has-cover,
	:global(.grid-mode) .cover-top.has-cover {
		@apply md:flex-col-reverse;
	}

	:global(.list-mode) .cover-top.has-cover .post-card-content,
	:global(.grid-mode) .cover-top.has-cover .post-card-content {
		@apply md:w-full md:pr-9;
	}

	@media (min-width: 768px) {
		/* 顶置封面在列表模式下采用浅横幅，保持内容阅读节奏 */
		:global(.list-mode) .cover-top.has-cover .post-card-image {
			@apply mx-4 mt-4 -mb-2;
			max-height: 12rem;
			aspect-ratio: 3 / 1;
		}

		/* Grid 顶图模式参考 Firefly 的卡片比例，但保持现有容器逻辑 */
		:global(.grid-mode) .cover-top.has-cover {
			@apply h-full;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-image {
			@apply w-full max-h-none mx-0 mt-0 mb-0;
			border-radius: var(--radius-large) var(--radius-large) 0 0;
			aspect-ratio: 2 / 1;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-content {
			@apply px-5 pt-4 pb-5;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-title-link {
			@apply text-2xl mb-2 before:hidden;
			line-height: 1.75rem;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-meta {
			@apply mb-3;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-description {
			@apply mb-3 pr-0;
			display: -webkit-box;
			-webkit-box-orient: vertical;
			overflow: hidden;
			-webkit-line-clamp: 2;
			line-clamp: 2;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-tags {
			@apply gap-1.5 mt-1;
		}

		:global(.grid-mode) .cover-top.has-cover .post-card-tags a {
			@apply text-[0.7rem] px-1.5 py-0.5;
		}
	}
</style>
