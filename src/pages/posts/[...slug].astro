---
import type { CollectionEntry } from "astro:content";
import { render, getCollection } from "astro:content";
import path from "node:path";
import Comment from "@components/comment/index.astro";
import License from "@components/misc/License.astro";
import Markdown from "@components/misc/Markdown.astro";
import SharePoster from "@components/misc/SharePoster.svelte";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import {
	getFileDirFromPath,
	getPostUrlBySlug,
	removeFileExtension,
} from "@utils/url-utils";
import {
	getSortedPosts,
} from "@utils/content-utils";
import {
	hasCustomPermalink,
	initPostIdMap,
} from "@utils/permalink-utils";
import { Icon } from "astro-icon/components";
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import { licenseConfig, permalinkConfig, shareConfig } from "src/config";
import ImageWrapper from "../../components/misc/ImageWrapper.astro";
import PostMetadata from "../../components/PostMeta.astro";
import { profileConfig, siteConfig } from "../../config";
import { formatDateToYYYYMMDD } from "../../utils/date-utils";
import Encryptor from "../../components/Encryptor.astro";

export async function getStaticPaths() {
	const blogEntries = await getSortedPosts();

	// 初始化文章 ID 映射（用于 %post_id% 占位符）
	initPostIdMap(blogEntries);

	const paths: {
		params: { slug: string };
		props: { entry: CollectionEntry<"posts"> };
	}[] = [];

	for (const entry of blogEntries) {
		// 将 id 转换为 slug（移除扩展名）以匹配路由参数
		const defaultSlug = removeFileExtension(entry.id);


		// 如果文章有自定义 permalink，不在 /posts/ 下创建路径
		// 而是通过根目录的 [permalink].astro 处理
		if (hasCustomPermalink(entry)) {
			// 仍然需要在 /posts/ 下创建默认路径以便兼容旧链接
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
			continue;
		}

		// 如果全局 permalink 功能启用，不在 /posts/ 下创建路径
		// 而是通过根目录的 [permalink].astro 处理
		if (permalinkConfig.enable) {
			// 仍然保留默认 slug 路径以便兼容旧链接
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});
		} else {
			// 全局 permalink 功能未启用
			// 为每篇文章创建默认的 slug 路径
			paths.push({
				params: { slug: defaultSlug },
				props: { entry },
			});

			// 如果文章有 alias，也创建对应的路径
			if (entry.data.alias) {
				// 移除开头的斜杠和结尾的斜杠
				// 同时移除可能的 "posts/" 前缀，避免重复
				let alias = entry.data.alias
					.replace(/^\/+/, "")
					.replace(/\/+$/, "");
				if (alias.startsWith("posts/")) {
					alias = alias.replace(/^posts\//, "");
				}
				paths.push({
					params: { slug: alias },
					props: { entry },
				});
			}
		}
	}

	return paths;
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);
const { remarkPluginFrontmatter } = await render(entry);

// Process cover image for SharePoster
let posterCoverUrl = entry.data.image;
if (entry.data.image) {
	const isLocal = !(
		entry.data.image.startsWith("/") ||
		entry.data.image.startsWith("http") ||
		entry.data.image.startsWith("https") ||
		entry.data.image.startsWith("data:")
	);
	if (isLocal) {
		const basePath = getFileDirFromPath(entry.filePath || "");
		const files = import.meta.glob<ImageMetadata>("../../**", {
			import: "default",
		});
		let normalizedPath = path
			.normalize(path.join("../../", basePath, entry.data.image))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (file) {
			const img = await file();
			posterCoverUrl = img.src;
		}
	} else if (entry.data.image.startsWith("http")) {
		try {
			const response = await fetch(entry.data.image);
			const arrayBuffer = await response.arrayBuffer();
			const base64 = Buffer.from(arrayBuffer).toString("base64");
			const contentType = response.headers.get("content-type") || "image/jpeg";
			posterCoverUrl = `data:${contentType};base64,${base64}`;
		} catch {
			posterCoverUrl = entry.data.image;
		}
	}
}

// Process avatar image for SharePoster
let posterAvatarUrl = profileConfig.avatar;
if (profileConfig.avatar) {
	const isLocal = !(
		profileConfig.avatar.startsWith("/") ||
		profileConfig.avatar.startsWith("http") ||
		profileConfig.avatar.startsWith("https") ||
		profileConfig.avatar.startsWith("data:")
	);
	if (isLocal) {
		const files = import.meta.glob<ImageMetadata>("../../**", {
			import: "default",
		});
		let normalizedPath = path
			.normalize(path.join("../../", profileConfig.avatar))
			.replace(/\\/g, "/");
		const file = files[normalizedPath];
		if (file) {
			const img = await file();
			posterAvatarUrl = img.src;
		}
	}
}

// 判断是否为加密文章
let isEncrypted = entry.data.encrypted && entry.data.password;

// 查询同系列的所有文章
let seriesEpisodes: { id: string; title: string; order: number; url: string; isCurrent: boolean }[] = [];
if (entry.data.series && entry.data.series.trim() !== "") {
	const allPosts = await getCollection("posts", ({ data }) => {
		return data.series === entry.data.series && (!import.meta.env.PROD || data.draft !== true);
	});
	seriesEpisodes = allPosts
		.map((post) => ({
			id: post.id,
			title: post.data.title,
			order: post.data.seriesOrder ?? 0,
			url: getPostUrlBySlug(post.id),
			isCurrent: post.id === entry.id,
		}))
		.sort((a, b) => a.order - b.order);
}

// 判断是否为小说文章
const isNovel = entry.data.category === '小说';

// 计算小说的上一章/下一章
let prevChapter: { title: string; url: string } | null = null;
let nextChapter: { title: string; url: string } | null = null;
if (isNovel && seriesEpisodes.length > 1) {
	const currentIndex = seriesEpisodes.findIndex((ep) => ep.isCurrent);
	if (currentIndex > 0) {
		prevChapter = { title: seriesEpisodes[currentIndex - 1].title, url: seriesEpisodes[currentIndex - 1].url };
	}
	if (currentIndex < seriesEpisodes.length - 1) {
		nextChapter = { title: seriesEpisodes[currentIndex + 1].title, url: seriesEpisodes[currentIndex + 1].url };
	}
}

dayjs.extend(utc);
const lastModified = dayjs(entry.data.updated || entry.data.published)
	.utc()
	.format("YYYY-MM-DDTHH:mm:ss");

const jsonLd = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	headline: entry.data.title,
	description: entry.data.description || entry.data.title,
	keywords: entry.data.tags,
	author: {
		"@type": "Person",
		name: profileConfig.name,
		url: Astro.site,
	},
	datePublished: formatDateToYYYYMMDD(entry.data.published),
	inLanguage: entry.data.lang
		? entry.data.lang.replace("_", "-")
		: siteConfig.lang.replace("_", "-"),
	// TODO include cover image here
};
---

<MainGridLayout
    banner={entry.data.image}
    title={entry.data.title}
    description={entry.data.description}
    lang={entry.data.lang}
    setOGTypeArticle={true}
    postSlug={entry.id}
    headings={headings}
>
    <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- 引入右侧边栏布局管理器 -->
  <script>
    import('../../scripts/right-sidebar-layout.js');
  </script>
    <div
        class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative mb-4"
    >
        <div
            id="post-container"
            class:list={[
                "card-base z-10 px-6 md:px-9 pt-6 pb-4 relative w-full ",
                { 'novel-reading': isNovel },
            ]}
        >
            <!-- word count and reading time -->
            <div
                class="flex flex-row text-black/30 dark:text-white/30 gap-5 mb-3 transition onload-animation"
            >
                <div class="flex flex-row items-center">
                    <div
                        class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2"
                    >
                        <Icon name="material-symbols:notes-rounded" />
                    </div>
                    <div class="text-sm">
                        {remarkPluginFrontmatter.words}
                        {" " + i18n(I18nKey.wordsCount)}
                    </div>
                </div>
                <div class="flex flex-row items-center">
                    <div
                        class="transition h-6 w-6 rounded-md bg-black/5 dark:bg-white/10 text-black/50 dark:text-white/50 flex items-center justify-center mr-2"
                    >
                        <Icon
                            name="material-symbols:schedule-outline-rounded"
                        />
                    </div>
                    <div class="text-sm">
                        {remarkPluginFrontmatter.minutes}
                        {
                            " " +
                                i18n(
                                    remarkPluginFrontmatter.minutes === 1
                                        ? I18nKey.minuteCount
                                        : I18nKey.minutesCount,
                                )
                        }
                    </div>
                </div>
            </div>

            <!-- title -->
            <div class="relative onload-animation">
                <div
                    data-pagefind-body
                    data-pagefind-weight="10"
                    data-pagefind-meta="title"
                    class="transition w-full block font-bold mb-3
                    text-3xl md:text-[2.25rem]/[2.75rem]
                    text-black/90 dark:text-white/90
                    md:before:w-1 before:h-5 before:rounded-md before:bg-[var(--primary)]
                    before:absolute before:top-[0.75rem] before:left-[-1.125rem]"
                >
                    {entry.data.title}
                </div>
            </div>

            <!-- metadata -->
            <div class="onload-animation">
                <PostMetadata
                    className="mb-5"
                    published={entry.data.published}
                    updated={entry.data.updated}
                    tags={entry.data.tags}
                    category={entry.data.category || undefined}
                    id={entry.id}
                />
                {
                    (!entry.data.image|| (entry.data.image && !siteConfig.showCoverInContent)) && (
                        <div class="mt-4 border-[var(--line-divider)] border-dashed border-b-[1px] mb-5" />
                    )
                }
            </div>

            <!-- always show cover as long as it has one -->

            {
                entry.data.image && siteConfig.showCoverInContent && (
                    <>
                        <div class="mt-4" />
                        <ImageWrapper
                            id="post-cover"
                            src={entry.data.image}
                            basePath={getFileDirFromPath(entry.filePath || '')}
                            class="mb-8 rounded-xl banner-container onload-animation"
                        />
                    </>
                )
            }

            {
                isEncrypted ? (
                    <Encryptor password={entry.data.password}>
                         <Markdown class="mb-6 markdown-content onload-animation">
                            <Content />
                        </Markdown>
                    </Encryptor>
                ) : (
                    <Markdown class="mb-6 markdown-content onload-animation">
                        <Content />
                    </Markdown>
                )
            }

            {/* 同系列选集/章节面板 */}
            {seriesEpisodes.length > 1 && !isNovel && (
                <div class="mt-6 mb-6 p-5 bg-[var(--license-block-bg)] rounded-xl onload-animation">
                    <div class="flex items-center gap-2 mb-4">
                        <Icon name="material-symbols:video-library-rounded" class="text-2xl text-[var(--primary)]" />
                        <span class="font-bold text-lg text-black/80 dark:text-white/80">
                            📺 系列选集
                        </span>
                        <span class="text-sm text-black/50 dark:text-white/50">
                            {entry.data.series} · 共{seriesEpisodes.length}集
                        </span>
                    </div>
                    <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-2">
                        {seriesEpisodes.map((ep) => (
                            <a
                                href={ep.isCurrent ? "#" : ep.url}
                                class:list={[
                                    "rounded-lg px-3 py-2 text-center text-sm font-medium transition-all duration-200 truncate",
                                    ep.isCurrent
                                        ? "bg-[var(--primary)] text-white shadow-md cursor-default"
                                        : "btn-card hover:shadow-sm text-black/70 dark:text-white/70 hover:text-[var(--primary)]",
                                ]}
                                title={ep.title}
                            >
                                {ep.order > 0 ? `第${ep.order}集` : ep.title.slice(0, 8)}
                            </a>
                        ))}
                    </div>
                </div>
            )}

            {/* 小说上一章/下一章导航 */}
            {isNovel && seriesEpisodes.length > 1 && (
                <div class="flex justify-between items-center gap-3 mt-6 mb-4 onload-animation">
                    {prevChapter ? (
                        <a href={prevChapter.url}
                           class="flex items-center gap-2 btn-card rounded-xl px-4 py-3 text-sm font-medium text-black/70 dark:text-white/70 hover:text-[var(--primary)] transition-all max-w-[45%]">
                            <Icon name="material-symbols:chevron-left-rounded" class="text-xl text-[var(--primary)] flex-shrink-0" />
                            <span class="truncate">上一章</span>
                        </a>
                    ) : <div />}
                    {nextChapter ? (
                        <a href={nextChapter.url}
                           class="flex items-center gap-2 btn-card rounded-xl px-4 py-3 text-sm font-medium text-black/70 dark:text-white/70 hover:text-[var(--primary)] transition-all max-w-[45%] ml-auto">
                            <span class="truncate">下一章</span>
                            <Icon name="material-symbols:chevron-right-rounded" class="text-xl text-[var(--primary)] flex-shrink-0" />
                        </a>
                    ) : <div />}
                </div>
            )}

            {/* 小说章节列表（可折叠） */}
            {isNovel && seriesEpisodes.length > 1 && (
                <div class="mb-6 bg-[var(--license-block-bg)] rounded-xl onload-animation overflow-hidden" id="novel-chapter-panel">
                    <button
                        class="w-full flex items-center justify-between gap-2 p-4 hover:bg-black/5 dark:hover:bg-white/5 transition-colors cursor-pointer"
                        id="novel-chapter-toggle"
                        type="button"
                    >
                        <div class="flex items-center gap-2">
                            <Icon name="material-symbols:menu-book-rounded" class="text-2xl text-[var(--primary)]" />
                            <span class="font-bold text-lg text-black/80 dark:text-white/80">
                                📖 章节目录
                            </span>
                            <span class="text-sm text-black/50 dark:text-white/50">
                                {entry.data.series} · 共{seriesEpisodes.length}章
                            </span>
                        </div>
                        <Icon name="material-symbols:expand-more-rounded" class="text-2xl text-black/40 dark:text-white/40 transition-transform" id="novel-chapter-arrow" />
                    </button>
                    <div class="max-h-0 overflow-hidden transition-all duration-300" id="novel-chapter-list">
                        <div class="max-h-[400px] overflow-y-auto px-2 pb-3">
                            {seriesEpisodes.map((ep, idx) => (
                                <a
                                    href={ep.isCurrent ? "#" : ep.url}
                                    class:list={[
                                        "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm transition-all duration-200",
                                        ep.isCurrent
                                            ? "bg-[var(--primary)] text-white font-bold shadow-md"
                                            : "hover:bg-black/5 dark:hover:bg-white/5 text-black/70 dark:text-white/70 hover:text-[var(--primary)]",
                                    ]}
                                    data-current={ep.isCurrent ? "true" : undefined}
                                >
                                    <span class:list={[
                                        "flex-shrink-0 w-8 h-8 rounded-md flex items-center justify-center text-xs font-bold",
                                        ep.isCurrent
                                            ? "bg-white/20 text-white"
                                            : "bg-black/5 dark:bg-white/10 text-black/40 dark:text-white/40",
                                    ]}>
                                        {idx + 1}
                                    </span>
                                    <span class="truncate">{ep.title}</span>
                                </a>
                            ))}
                        </div>
                    </div>
                </div>
            )}

            {shareConfig.enable && (
                <div id="share-component" class:list={["p-6 bg-[var(--license-block-bg)] rounded-xl mb-6 onload-animation", { "encrypted-hidden": isEncrypted }]}>
                    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
                        <div class="flex items-center gap-3 flex-1">
                            <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-[var(--enter-btn-bg)]">
                                <Icon
                                    name="material-symbols:share"
                                    class="text-3xl text-[var(--primary)]"
                                />
                            </div>
                            <div class="flex flex-col gap-1">
                                <div class="text-[1.0rem] leading-tight text-black/75 dark:text-white/75">
                                    {i18n(I18nKey.shareOnSocial)}
                                </div>
                                <p class="text-[0.8rem] leading-tight text-black/75 dark:text-white/75">
                                    {i18n(I18nKey.shareOnSocialDescription)}
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <SharePoster
                                client:load
                                title={entry.data.title}
                                author={entry.data.author || profileConfig.name}
                                description={entry.data.description || ""}
                                pubDate={formatDateToYYYYMMDD(entry.data.published)}
                                coverImage={posterCoverUrl}
                                url={Astro.url.toString()}
                                siteTitle={siteConfig.title}
                                avatar={posterAvatarUrl}
                            />
                        </div>
                    </div>
                </div>
            )}

            {licenseConfig.enable && (
                <div id="license-component" class:list={["encrypted-hidden-wrapper", { "encrypted-hidden": isEncrypted }]}>
                    <License
                    title={entry.data.title}
                    id={entry.id}
                    pubDate={entry.data.published}
                    author={entry.data.author}
                    sourceLink={entry.data.sourceLink}
                    licenseName={entry.data.licenseName}
                    licenseUrl={entry.data.licenseUrl}
                    class="mb-6 rounded-xl license-container onload-animation"
                />
                </div>
            )}


        </div>
    </div>

    <!-- 评论 -->
    <Comment post={entry} />

    {siteConfig.showLastModified && (
        <>
            <div
                id="last-modified"
                data-last-modified={lastModified}
                data-prefix={i18n(I18nKey.lastModifiedPrefix)}
                data-year={i18n(I18nKey.year)}
                data-month={i18n(I18nKey.month)}
                data-day={i18n(I18nKey.day)}
                data-hour={i18n(I18nKey.hour)}
                data-minute={i18n(I18nKey.minute)}
                data-second={i18n(I18nKey.second)}
                style="display: none;"
            ></div>

            <div class="card-base p-6 mb-4">
                <script is:inline>
                    function runtime() {
                        const lastModifiedElement = document.getElementById('last-modified');
                        if (!lastModifiedElement) return;  // 如果元素不存在，直接返回
                        
                        const startDate = new Date(lastModifiedElement.dataset.lastModified);
                        const currentDate = new Date();
                        const diff = currentDate - startDate;
                        const seconds = Math.floor(diff / 1000);
                        const days = Math.floor(seconds / 86400);
                        const hours = Math.floor((seconds % 86400) / 3600);
                        const minutes = Math.floor((seconds % 3600) / 60);
                        const secs = seconds % 60;

                        const years = Math.floor(days / 365);
                        const months = Math.floor((days % 365) / 30);
                        const remainingDays = days % 30;

                        const prefix = lastModifiedElement.dataset.prefix;
                        const yearKey = lastModifiedElement.dataset.year;
                        const monthKey = lastModifiedElement.dataset.month;
                        const dayKey = lastModifiedElement.dataset.day;
                        const hourKey = lastModifiedElement.dataset.hour;
                        const minuteKey = lastModifiedElement.dataset.minute;
                        const secondKey = lastModifiedElement.dataset.second;

                        let runtimeString = prefix + ' ';
                        if (years > 0) {
                            runtimeString += `${years} ${yearKey} `;
                        }
                        if (months > 0) {
                            runtimeString += `${months} ${monthKey} `;
                        }
                        if (remainingDays > 0) {
                            runtimeString += `${remainingDays} ${dayKey} `;
                        }
                        runtimeString += `${hours} ${hourKey} `;
                        if (minutes < 10) {
                            runtimeString += `0${minutes} ${minuteKey} `;
                        } else {
                            runtimeString += `${minutes} ${minuteKey} `;
                        }
                        if (secs < 10) {
                            runtimeString += `0${secs} ${secondKey}`;
                        } else {
                            runtimeString += `${secs} ${secondKey}`;
                        }

                        document.getElementById("modifiedtime").innerHTML = runtimeString;
                    }
                    setInterval(runtime, 1000);
                </script>
                <div class="flex items-center gap-3">
                    <div class="flex items-center justify-center h-12 w-12 rounded-lg bg-[var(--enter-btn-bg)]">
                        <Icon
                            name="material-symbols:history-rounded"
                            class="text-3xl text-[var(--primary)]"
                        />
                    </div>
                    <div class="flex flex-col gap-1">
                        <div id="modifiedtime" class="text-[1.0rem] leading-tight text-black/75 dark:text-white/75"></div>
                        <p class="text-[0.8rem] leading-tight text-black/75 dark:text-white/75">
                            {i18n(I18nKey.lastModifiedOutdated)}
                        </p>
                    </div>
                </div>
            </div>
        </>
    )}

    <div
        class="flex flex-col md:flex-row justify-between mb-4 gap-4 overflow-hidden w-full"
    >
        <a
            href={entry.data.nextSlug
                ? getPostUrlBySlug(entry.data.nextSlug)
                : "#"}
            class:list={[
                "w-full font-bold overflow-hidden active:scale-95",
                { "pointer-events-none": !entry.data.nextSlug },
            ]}
        >
            {
                entry.data.nextSlug && (
                    <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-start gap-4">
                        <Icon
                            name="material-symbols:chevron-left-rounded"
                            class="text-[2rem] text-[var(--primary)]"
                        />
                        <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                            {entry.data.nextTitle}
                        </div>
                    </div>
                )
            }
        </a>

        <a
            href={entry.data.prevSlug
                ? getPostUrlBySlug(entry.data.prevSlug)
                : "#"}
            class:list={[
                "w-full font-bold overflow-hidden active:scale-95",
                { "pointer-events-none": !entry.data.prevSlug },
            ]}
        >
            {
                entry.data.prevSlug && (
                    <div class="btn-card rounded-2xl w-full h-[3.75rem] max-w-full px-4 flex items-center !justify-end gap-4">
                        <div class="overflow-hidden transition overflow-ellipsis whitespace-nowrap max-w-[calc(100%_-_3rem)] text-black/75 dark:text-white/75">
                            {entry.data.prevTitle}
                        </div>
                        <Icon
                            name="material-symbols:chevron-right-rounded"
                            class="text-[2rem] text-[var(--primary)]"
                        />
                    </div>
                )
            }
        </a>
    </div>

<script is:inline>
// 小说章节目录折叠/展开
(function() {
    const toggle = document.getElementById('novel-chapter-toggle');
    const list = document.getElementById('novel-chapter-list');
    const arrow = document.getElementById('novel-chapter-arrow');
    if (!toggle || !list) return;

    let isOpen = false;
    toggle.addEventListener('click', function() {
        isOpen = !isOpen;
        if (isOpen) {
            list.style.maxHeight = list.scrollHeight + 'px';
            if (arrow) arrow.style.transform = 'rotate(180deg)';
            // 滚动到当前章节
            setTimeout(function() {
                const current = list.querySelector('[data-current="true"]');
                if (current) {
                    current.scrollIntoView({ block: 'center', behavior: 'smooth' });
                }
            }, 350);
        } else {
            list.style.maxHeight = '0';
            if (arrow) arrow.style.transform = 'rotate(0deg)';
        }
    });
})();
</script>

